# ── Firebase Web SDK (required) ──────────────────────────────────────────────
# Copy this file to .env.local and fill in your Firebase project values.
# Get these from: Firebase Console → Project settings → Your apps → Web app

VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX   # optional (Analytics)

# ── Firebase Functions base URL ───────────────────────────────────────────────
# For local dev with the emulator: http://127.0.0.1:5001/YOUR_PROJECT_ID/us-central1
# For production: https://us-central1-YOUR_PROJECT_ID.cloudfunctions.net
VITE_FUNCTIONS_BASE_URL=https://us-central1-your_project_id.cloudfunctions.net

# NOTE: Replace YOUR_FIREBASE_PROJECT_ID in .firebaserc with your actual project ID
